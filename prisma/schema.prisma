// Prisma schema for MLS Employee Portal.
// Standard Auth.js tables (User, Account, Session, VerificationToken)
// plus a Role enum for RBAC.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  // privilege roles (controls what they can DO in the portal). split
  // into two tiers right now:
  //   ELEVATED:  IT_ADMIN, ADMIN, MANAGER  (can manage users + content)
  //   STANDARD:  HR, SUPERVISOR, STAFF      (read-only access)
  // we may split the two ELEVATED levels apart later - for now all three
  // map to the same permission set. see src/lib/roles.js for the helper.
  IT_ADMIN
  ADMIN
  MANAGER
  HR
  SUPERVISOR
  STAFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)
  // job title separate from privilege role. free-form string so we can
  // add new ones without a schema migration. examples: "Owner/Director",
  // "Program Manager", "Field Supervisor", "HR Administrator", "ILS",
  // "Day Program", "Supported Living", etc.
  title         String?
  // soft delete - when set, this user cant sign in anymore. preserves
  // history (audit trails, role at time of action, etc.) rather than
  // hard deleting the row. set back to null to reactivate.
  deactivatedAt DateTime?
  // their actual employment start date with MLS (per HR records).
  // separate from createdAt which is just when their row was added to
  // our portal db. used for tenure displays + sorting in the admin list.
  hireDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  likes         PostLike[]
}

// MLS Hub - internal feed for posts (flyers, helpful info) + comments.
// soft-deleted via deletedAt so threads dont collapse if an author leaves.
model Post {
  id         String     @id @default(cuid())
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  imageUrl   String?
  // tag string is validated against the list in src/lib/hub.js. kept as
  // free string so we can add new tags without a migration.
  tag        String
  // optional expiration. once past, the post shows an "Expired" badge
  // and drops below active posts in the feed.
  expiresAt  DateTime?
  // pinning is admin-only. null = not pinned. when set, post floats to
  // top of the feed.
  pinnedAt   DateTime?
  pinnedById String?
  // edit tracking. null = never edited. set explicitly by edit action.
  editedAt   DateTime?
  // soft delete. set to a timestamp by the delete action.
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  comments   Comment[]
  likes      PostLike[]

  @@index([createdAt])
  @@index([pinnedAt])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
}

// PostLike is the join table for the heart/like reaction. composite PK
// so each user can only like a post once. removing the row = unlike.
model PostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
