// Prisma schema for MLS Employee Portal.
// Standard Auth.js tables (User, Account, Session, VerificationToken)
// plus a Role enum for RBAC.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  // privilege roles (controls what they can DO in the portal).
  //   SUPER:     full access to everything. hidden role - only IT can
  //              see/assign it. red badge. used for top-level superusers.
  //   ELEVATED:  IT_ADMIN, ADMIN, MANAGER  (can manage users + content)
  //   STANDARD:  HR, SUPERVISOR, STAFF      (read-only access)
  // see src/lib/roles.js for the permission helpers.
  SUPER
  IT_ADMIN
  ADMIN
  MANAGER
  HR
  SUPERVISOR
  STAFF
}

model User {
  id            String    @id @default(cuid())
  // full / legal name (records). managed by admin/HR. shown only on the contact
  // detail card + admin panel (gated to admin/management when hideLegalName).
  name          String?
  // optional preferred first / last name. self-editable in settings. the name
  // shown everywhere = (preferredFirstName or legal first) + (preferredLastName
  // or legal last), e.g. "Manu" + legal last "Uribe" -> "Manu Uribe".
  preferredFirstName String?
  preferredLastName  String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)
  // job title separate from privilege role. free-form string so we can
  // add new ones without a schema migration. examples: "Owner/Director",
  // "Program Manager", "Field Supervisor", "HR Administrator", "ILS",
  // "Day Program", "Supported Living", etc.
  title         String?
  // soft delete - when set, this user cant sign in anymore. preserves
  // history (audit trails, role at time of action, etc.) rather than
  // hard deleting the row. set back to null to reactivate.
  deactivatedAt DateTime?
  // their actual employment start date with MLS (per HR records).
  // separate from createdAt which is just when their row was added to
  // our portal db. used for tenure displays + sorting in the admin list.
  hireDate      DateTime?
  // contact phone for the team directory. self-editable in Settings,
  // admins can also set it. stored as the raw string the user typed.
  phone         String?
  // free-text working hours shown on their contact detail page, e.g.
  // "Mon-Fri 9am-5pm". self-editable in Settings, admins too.
  workingHours  String?
  // when false, the phone is hidden on the PUBLIC shared contact link
  // (/c/[id]). still shown to signed-in staff in the portal. opt-out in
  // Settings; defaults to sharing.
  sharePhonePublicly Boolean @default(true)
  // when true, the full/legal name is hidden from coworkers + the public link -
  // only the oversight tier (HR/management) + the person themselves see it.
  // self-set in settings. they should have a display name set so something
  // still shows.
  hideLegalName Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  posts         Post[]     @relation("PostAuthor")
  postedPosts   Post[]     @relation("PostPostedBy")
  comments      Comment[]
  likes         PostLike[]
  announcements        Announcement[]        @relation("AnnouncementAuthor")
  announcementsPosted  Announcement[]        @relation("AnnouncementPostedBy")
  announcementComments AnnouncementComment[]
  announcementLikes    AnnouncementLike[]
  announcementAcks     AnnouncementAck[]
  announcementMeetingChoices AnnouncementMeetingChoice[]
  nlSubmitted   NewsletterItem[] @relation("NLSubmittedBy")
  nlApproved    NewsletterItem[] @relation("NLApprovedBy")
  nlPublished   NewsletterItem[] @relation("NLPublishedBy")
  feedbackAuthored FeedbackItem[] @relation("FeedbackAuthor")
  feedbackResolved FeedbackItem[] @relation("FeedbackResolvedBy")
  resourcesSubmitted Resource[]   @relation("ResourceSubmittedBy")
  resourcesApproved  Resource[]   @relation("ResourceApprovedBy")
  resourcesVerified  Resource[]   @relation("ResourceVerifiedBy")
  sitePhotos    SitePhoto[]   @relation("SitePhotoUploadedBy")
  notifications Notification[]
}

// company device / asset log. viewable by the oversight tier; editing is
// Admin and up (role-based, see src/lib/roles.js). tracks Apple + other
// hardware David purchases.
enum DeviceType {
  LAPTOP
  DESKTOP
  TABLET
  PHONE
  OTHER
}

enum DeviceStatus {
  IN_USE
  STORAGE
  REPAIR
  RETIRED
}

model Device {
  id           String       @id @default(cuid())
  name         String       // e.g. "David's MacBook Pro 16"
  type         DeviceType   @default(LAPTOP)
  serialNumber String?
  // purchase price stored in whole cents to avoid float rounding.
  priceCents   Int?
  purchaseDate DateTime?
  // free text: who has it / where it lives, e.g. "David - home office".
  assignedTo   String?
  status       DeviceStatus @default(IN_USE)
  notes        String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
}

// external partners / community resources for the team contacts page
// (e.g. Integrity Cottages, food banks, clinics). staff submit, IT or
// management approve before they show on the directory.
enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

// operational state - is the place actually running. distinct from the
// ResourceStatus above, which is the moderation/approval workflow.
enum ResourceOpStatus {
  ACTIVE
  TEMPORARILY_UNAVAILABLE
  NEEDS_VERIFICATION
  CLOSED
}

model Resource {
  id          String         @id @default(cuid())
  name        String
  // top-level bucket shown as a chip, e.g. "Housing", "Food banks".
  category    String?
  // finer type within the category, e.g. "Food pantry", "Mobile food
  // distribution". options are per-category (see src/lib/contacts.js).
  subtype     String?
  // organization behind the location, if different from the resource name.
  orgName     String?
  phone       String?
  email       String?
  website     String?
  // direct link to book/schedule, if they take appointments online.
  appointmentLink String?
  // free text, e.g. "Call before visiting" or "Text to schedule".
  contactInstructions String?
  address     String?
  city        String?
  state       String?
  zip         String?
  // who the service covers, e.g. "Anaheim residents only". free text.
  serviceArea String?
  lat         Float?
  lng         Float?
  // legacy free-text hours. superseded by `schedule` for new entries but
  // kept so the imported food-bank hours still show.
  hours       String?
  // structured recurring schedule rows: [{ day, frequency, start, end }]
  schedule    Json?
  // populations served (multi). filterable. see WHO_IT_SERVES_OPTIONS.
  whoItServes String[]       @default([])
  appointmentRequired Boolean @default(false)
  // category-specific answers (eligibility + food details). see
  // buildDetails in src/lib/contacts.js for the shape.
  details     Json?
  // short public-facing description / what they do.
  notes       String?
  // staff-only notes, never shown to clients.
  internalNotes String?
  // where this info came from (url, person, flyer).
  source      String?
  operationalStatus ResourceOpStatus @default(ACTIVE)
  // featured by management - surfaces in a "Staff picks" row up top.
  staffPick   Boolean        @default(false)
  // verification trail so the directory doesn't go stale.
  lastVerifiedAt DateTime?
  verifiedById   String?
  verifiedBy     User?        @relation("ResourceVerifiedBy", fields: [verifiedById], references: [id])
  status      ResourceStatus @default(PENDING)
  submittedById String
  submittedBy   User         @relation("ResourceSubmittedBy", fields: [submittedById], references: [id])
  approvedById  String?
  approvedBy    User?        @relation("ResourceApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  reviewNote    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
}

// photos shown on the public About page, managed from the portal by
// admin/IT so they can swap site imagery without a code change. uploaded
// to vercel blob; we only keep the url + a bit of metadata here.
model SitePhoto {
  id               String   @id @default(cuid())
  url              String
  // which spot on the public page: "about-hero" | "agency-overview" |
  // "partnership". validated against src/lib/site-photos.js.
  section          String
  caption          String?
  // alt text for screen readers / when the image cant load.
  alt              String?
  // order within a section (low = first). drives the slideshow order.
  sortOrder        Int      @default(0)
  // turned off to hide from the site without deleting the upload.
  active           Boolean  @default(true)
  // uploader attests a signed photo release is on file for anyone pictured.
  consentConfirmed Boolean  @default(false)
  uploadedById     String?
  uploadedBy       User?    @relation("SitePhotoUploadedBy", fields: [uploadedById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([section, sortOrder])
}

// MLS Hub - internal feed for posts (flyers, helpful info) + comments.
// soft-deleted via deletedAt so threads dont collapse if an author leaves.
model Post {
  id         String     @id @default(cuid())
  authorId   String
  author     User       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  imageUrl   String?
  // when an IT/admin posts on behalf of someone else, authorId is the
  // person being credited and postedById is who actually hit submit.
  // null when the author posted it themselves. kept for the audit trail.
  postedById String?
  postedBy   User?      @relation("PostPostedBy", fields: [postedById], references: [id])
  // tag string is validated against the list in src/lib/hub.js. kept as
  // free string so we can add new tags without a migration.
  tag        String
  // optional expiration. once past, the post shows an "Expired" badge
  // and drops below active posts in the feed.
  expiresAt  DateTime?
  // pinning is admin-only. null = not pinned. when set, post floats to
  // top of the feed.
  pinnedAt   DateTime?
  pinnedById String?
  // edit tracking. null = never edited. set explicitly by edit action.
  editedAt   DateTime?
  // soft delete. set to a timestamp by the delete action.
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  comments   Comment[]
  likes      PostLike[]

  @@index([createdAt])
  @@index([pinnedAt])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
}

// PostLike is the join table for the heart/like reaction. composite PK
// so each user can only like a post once. removing the row = unlike.
model PostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

// Announcements - a second internal feed, identical in shape to the Hub
// (Post/Comment/PostLike) but separate so it stays a clean broadcast board.
// only Supervisor+ can create announcements (see src/lib/roles.js
// isSupervisorUp); everyone reads, comments, and reacts.
model Announcement {
  id         String     @id @default(cuid())
  authorId   String
  author     User       @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // optional title - used by the Changelog type (Discord-style heading). plain
  // announcements leave it null and just use content.
  title      String?
  content    String
  imageUrl   String?
  // proxy posting: authorId is the credited person, postedById is who hit
  // submit (null when posted by themselves). kept for the audit trail.
  postedById String?
  postedBy   User?      @relation("AnnouncementPostedBy", fields: [postedById], references: [id])
  tag        String
  expiresAt  DateTime?
  pinnedAt   DateTime?
  pinnedById String?
  editedAt   DateTime?
  deletedAt  DateTime?
  // when true, staff get an "I read this" box and management gets a
  // who-has/who-hasnt roster. opt-in per announcement (see requireAck box
  // on the form). plain posts leave it false.
  requireAck Boolean    @default(false)
  // the acknowledgment audience - who is expected to acknowledge (drives the
  // roster denominator + the email send default). ackEveryone = the whole
  // expected-ack staff set; otherwise ackTitles lists the job titles targeted.
  ackEveryone Boolean   @default(true)
  ackTitles   String[]  @default([])
  // specific individuals to target (in addition to ackTitles), used when the
  // poster narrows a title role to certain people. unioned with ackTitles.
  ackUserIds  String[]  @default([])
  // Company Meeting fields (used when tag = "Company Meeting").
  meetingKind      String?  // Training | Team meeting | All-hands | Orientation | Other
  meetingFormat    String?  // zoom | in_person | hybrid
  meetingMandatory Boolean  @default(false)
  zoomLink         String?
  zoomCode         String?
  meetingAddress   String?
  // optional sessions to pick from: [{ id, label }]. empty = single meeting.
  meetingOptions   Json?
  // when true, attendees may pick more than one session.
  meetingMultiPick Boolean  @default(false)
  // the meeting's start as an absolute instant (UTC). each viewer sees it in
  // their own device timezone. meetingTimezone is the zone the author set it in
  // (IANA, e.g. America/New_York) - kept for editing + a "set in" label.
  meetingAt        DateTime?
  meetingTimezone  String?
  // duration estimate in minutes (from -> optional to for a range).
  meetingDurationFromMin Int?
  meetingDurationToMin   Int?
  meetingChoices   AnnouncementMeetingChoice[]
  // last time the "Send to staff by email" blast went out, so the roster
  // can show "last emailed ..." and re-sends only hit the un-acked.
  ackEmailSentAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  comments   AnnouncementComment[]
  likes      AnnouncementLike[]
  acks       AnnouncementAck[]

  @@index([createdAt])
  @@index([pinnedAt])
}

// read-receipt for an ack-required announcement. one row per person who
// acknowledged, composite PK so each person acks once. mirrors
// AnnouncementLike. viaEmail records whether they clicked the one-click
// email link or checked the box in the portal.
model AnnouncementAck {
  announcementId String
  userId         String
  viaEmail       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

model AnnouncementComment {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([announcementId, createdAt])
}

model AnnouncementLike {
  announcementId String
  userId         String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId])
}

// a person's pick(s) for a Company Meeting's session options. one row per
// chosen option, so a user can pick several when meetingMultiPick is on; the
// composite PK keeps each (user, option) unique. drives the who-picked-what
// roster.
model AnnouncementMeetingChoice {
  announcementId String
  userId         String
  optionId       String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([announcementId, userId, optionId])
}

// the Forms library - a managed list of blank form templates (PDFs). staff
// browse + download; fillable PDFs (AcroForm) can be filled in the browser and
// downloaded/sent. NO filled-in copies are ever stored here - only the blank
// templates. fileUrl points at a public /forms/* path or a Vercel Blob URL.
model Form {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String?
  fileUrl     String
  // true when the PDF has AcroForm fields, so it can be filled in-app.
  fillable    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// "This Week in My Life Services" newsletter. staff submit items, IT +
// management approve, then IT publishes them to the public /this-week
// page. lifecycle: SUBMITTED -> APPROVED -> PUBLISHED (or REJECTED).
enum NewsletterStatus {
  SUBMITTED
  APPROVED
  PUBLISHED
  REJECTED
}

// two flavors of item: a recap of something that happened ("this past
// week") or a heads-up about something coming up.
enum NewsletterCategory {
  PAST_WEEK
  UPCOMING
}

// internal suggestions + bug reports board. staff post recommendations
// or bugs they spot (blog-post style, optional screenshot). IT/management
// triage status so items get closed out - they're not meant to live
// forever like the newsletter.
enum FeedbackType {
  SUGGESTION
  BUG
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DECLINED
}

model FeedbackItem {
  id           String         @id @default(cuid())
  type         FeedbackType
  title        String
  body         String
  imageUrl     String?
  status       FeedbackStatus @default(OPEN)
  authorId     String
  author       User           @relation("FeedbackAuthor", fields: [authorId], references: [id])
  // who marked it resolved/declined + when. null while still open.
  resolvedById String?
  resolvedBy   User?          @relation("FeedbackResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([createdAt])
}

// in-portal notifications for the oversight tier. one row per recipient
// (events fan out to every oversight user), each tracking its own read state.
enum NotificationType {
  RESOURCE_PENDING
  FEEDBACK_NEW
  NEWSLETTER_PENDING
  USER_ADDED
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  // in-portal path to jump to, e.g. /portal/contacts/resources/review
  link      String?
  // recipient user.
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model NewsletterItem {
  id        String             @id @default(cuid())
  title     String
  body      String
  imageUrl  String?
  category  NewsletterCategory
  // optional date the event happened / will happen. shown on the public
  // page. separate from createdAt (when it was submitted).
  eventDate DateTime?
  status    NewsletterStatus   @default(SUBMITTED)
  // submitter attests written consent is on file for anyone pictured.
  // required by the server action whenever an image is attached.
  consentConfirmed Boolean      @default(false)
  // optional note from a reviewer - e.g. why something was rejected, or
  // a tweak request. shown back to the submitter.
  reviewNote String?

  submittedById String
  submittedBy   User    @relation("NLSubmittedBy", fields: [submittedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("NLApprovedBy", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  publishedById String?
  publishedBy   User?   @relation("NLPublishedBy", fields: [publishedById], references: [id])
  publishedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([publishedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
